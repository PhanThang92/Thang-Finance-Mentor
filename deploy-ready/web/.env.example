# ── Server port (default: 3000) ───────────────────────────────────────────────
PORT=3000

# ── Base path — use "/" for root deployment ───────────────────────────────────
BASE_PATH=/

# ── API server URL (for dev proxy and server.mjs) ─────────────────────────────
VITE_API_TARGET=http://localhost:8080
API_PORT=8080
