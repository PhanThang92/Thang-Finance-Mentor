# Replit
.cache/
.local/

# Environment variables — KHÔNG commit file này
.env
database_export.sql

# Media uploads — ignore toàn bộ nội dung, chỉ giữ cấu trúc thư mục qua .gitkeep
# Phải un-ignore từng subdir tường minh (git không recurse vào dir đã bị ignore)
uploads/**
!uploads/
!uploads/.gitkeep
!uploads/orig/
!uploads/orig/.gitkeep
!uploads/disp/
!uploads/disp/.gitkeep
!uploads/thumb/
!uploads/thumb/.gitkeep
backup_pvt_swc*
