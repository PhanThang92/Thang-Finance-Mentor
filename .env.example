# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Phan Văn Thắng SWC — cấu hình môi trường
#  Sao chép file này thành .env và điền giá trị thực
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Cổng cổng chạy ────────────────────────────────────────────────────
# Web server (node server.mjs) — dùng WEB_PORT hoặc PORT nếu Passenger set
WEB_PORT=3000
# API server (Express) — dùng API_PORT hoặc PORT nếu Passenger set
API_PORT=8080

# ── Chế độ chạy ───────────────────────────────────────────────────────
NODE_ENV=production

# ── Cơ sở dữ liệu ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pvt_swc

# ── Admin ─────────────────────────────────────────────────────────────
ADMIN_KEY=swc-admin-2026

# ── Email gửi đi (Resend) ─────────────────────────────────────────────
# Lấy API key tại: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@phanvanthang.net
RESEND_FROM_NAME=Phan Văn Thắng
RESEND_REPLY_TO=

# ── URL canonical ─────────────────────────────────────────────────────
SITE_URL=https://phanvanthang.net

# ── CORS (các domain được phép gọi API, phân tách bằng dấu phẩy) ──────
ALLOWED_ORIGINS=https://phanvanthang.net,https://www.phanvanthang.net

# ── Object Storage (Replit) ───────────────────────────────────────────
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public
STORAGE_PROVIDER=local

# ── Tích năng watermark ────────────────────────────────────────────────
WATERMARK_ENABLED=false

# ── Log level ─────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Sequence worker ───────────────────────────────────────────────────
SEQUENCE_WORKER_INTERVAL_MS=60000

# ── Đồng bộ Notion (tùy chọn) ────────────────────────────────────────
ENABLE_NOTION_SYNC=false
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Đồng bộ Google Sheets (tùy chọn) ─────────────────────────────────
ENABLE_GOOGLE_SHEETS_SYNC=false
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Leads
