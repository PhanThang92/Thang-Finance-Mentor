# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Phan Văn Thắng SWC — template biến môi trường
#
#  CÁCH DÙNG:
#   - Replit: Thêm từng biến qua Secrets panel (Tools → Secrets)
#   - Plesk / VPS / local: Copy file này thành .env rồi điền giá trị thực
#
#  LƯU Ý: Trên Replit, các biến DATABASE_URL / PGHOST / PG* /
#  DEFAULT_OBJECT_STORAGE_BUCKET_ID / SESSION_SECRET được tự động inject.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Chế độ chạy ───────────────────────────────────────────────────────
# production | development
NODE_ENV=production

# ── Cổng server ───────────────────────────────────────────────────────
# API Express server
API_PORT=8080
# Web/prerender server (server.mjs) — Plesk Passenger set PORT tự động
# Bỏ trống nếu dùng Passenger (nó inject PORT)
WEB_PORT=3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  CƠ SỞ DỮ LIỆU POSTGRESQL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# URL đầy đủ (ưu tiên dùng biến này):
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Hoặc từng biến riêng (driver tự ghép nếu không có DATABASE_URL):
PGHOST=localhost
PGPORT=5432
PGDATABASE=pvt_swc
PGUSER=postgres
PGPASSWORD=your_password_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  BẢO MẬT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Mật khẩu đăng nhập admin CMS — THAY NGAY khi triển khai production
ADMIN_KEY=swc-admin-2026

# Secret để ký session cookie — tạo bằng: openssl rand -base64 48
SESSION_SECRET=change_this_to_a_long_random_string

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MEDIA & LƯU TRỮ FILE
#  Media được lưu vào thư mục uploads/ trong project.
#  Serve qua: GET /api/uploads/<relativePath>
#  Cấu trúc:  uploads/orig/   — file gốc
#              uploads/disp/   — display WebP (full size)
#              uploads/thumb/  — thumbnail WebP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Đường dẫn tuyệt đối tới thư mục uploads (mặc định: <cwd>/uploads)
# Trên Plesk: đổi thành đường dẫn ngoài web root để bảo mật
# UPLOAD_DIR=/home/USERNAME/uploads

# Watermark ảnh upload
WATERMARK_ENABLED=false
# WATERMARK_TEXT=Phan Văn Thắng SWC

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL (Resend)
#  Bỏ trống RESEND_API_KEY = email bị tắt (no-op), app vẫn chạy bình thường
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Lấy API key tại: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@phanvanthang.net
RESEND_FROM_NAME=Phan Văn Thắng
# Địa chỉ reply-to (bỏ trống = dùng FROM_EMAIL)
RESEND_REPLY_TO=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  URL & CORS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SITE_URL=https://phanvanthang.net
# Các domain được phép gọi API (phân tách bằng dấu phẩy)
ALLOWED_ORIGINS=https://phanvanthang.net,https://www.phanvanthang.net

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  LOGGING & WORKER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Khoảng thời gian (ms) worker email sequence kiểm tra hàng đợi
SEQUENCE_WORKER_INTERVAL_MS=1800000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ĐỒNG BỘ NGOÀI (tùy chọn — bỏ trống = tắt)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Notion: tự động sync lead mới vào Notion database
ENABLE_NOTION_SYNC=false
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Google Sheets: tự động sync lead mới vào Google Spreadsheet
ENABLE_GOOGLE_SHEETS_SYNC=false
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Leads
